module benchmark/solution

type MyTree = MyLeaf | MyBranch(MyTree, MyTree)

func max_of(a: int, b: int) -> int = if a > b then a else b

export func tree_depth(t: MyTree) -> int =
  match t {
    MyLeaf => 1,
    MyBranch(l, r) => 1 + max_of(tree_depth(l), tree_depth(r))
  }

export func main() -> () ! {IO} = ()
